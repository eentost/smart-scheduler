# Application Environment
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# Database Configuration
POSTGRES_DB=smart_scheduler
POSTGRES_USER=admin
POSTGRES_PASSWORD=secure_password_change_me
DATABASE_URL=postgresql://admin:secure_password_change_me@db:5432/smart_scheduler

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=24h

# AI/ML Configuration
AI_MODEL_PATH=/app/models
ENABLE_ML_SCHEDULING=true
ML_MODEL_NAME=smart-scheduler-v1

# Logging
LOG_FORMAT=json
LOG_OUTPUT=stdout

# API Configuration
API_TIMEOUT=30000
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=15m

# Security
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
SECURE_COOKIES=false

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Feature Flags
FEATURE_INTELLIGENT_SCHEDULING=true
FEATURE_SMART_TIME_BLOCKING=true
FEATURE_DEADLINE_AWARENESS=true
FEATURE_BUFFER_TIME_MANAGEMENT=true
